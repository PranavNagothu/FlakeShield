# ─────────────────────────────────────────────────────────────────────────────
# FlakeShield Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=flakeshield
POSTGRES_USER=flakeshield
POSTGRES_PASSWORD=changeme

DATABASE_URL=postgresql+asyncpg://flakeshield:changeme@localhost:5432/flakeshield

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Go Analyzer gRPC ──────────────────────────────────────────────────────────
ANALYZER_GRPC_HOST=localhost
ANALYZER_GRPC_PORT=50051

# ── FastAPI Control Plane ──────────────────────────────────────────────────────
CONTROL_PLANE_HOST=0.0.0.0
CONTROL_PLANE_PORT=8000
SECRET_KEY=super-secret-jwt-key-change-in-prod
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── GitHub App ────────────────────────────────────────────────────────────────
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY_PATH=./github-app.pem
GITHUB_WEBHOOK_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Anthropic / Claude ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-3-5-sonnet-20241022

# ── AI Patch Generation ───────────────────────────────────────────────────────
AI_PATCH_ENABLED=false          # Set to true when you have a Claude API key
AI_PATCH_MOCK=true              # Uses deterministic mock patches when true

# ── pgvector embeddings ───────────────────────────────────────────────────────
EMBEDDINGS_ENABLED=false        # Enable once pgvector extension is active
EMBEDDING_MODEL=text-embedding-3-small

# ── AWS (Phase 4 only) ────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=
S3_REPORTS_BUCKET=flakeshield-reports
ECR_REGISTRY=

# ── Observability ────────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=flakeshield-control-plane
LOG_LEVEL=info
